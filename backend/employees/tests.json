{
  "tests": [
    {
      "name": "Получить список сотрудников",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Успешный вход Жилки О.В.",
      "method": "POST",
      "path": "/?action=login",
      "body": {
        "action": "login",
        "login": "OZhilka@rfgf.ru",
        "password": "123456"
      },
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"position": "Начальник отдела"}
    },
    {
      "name": "Неверный пароль отклоняется",
      "method": "POST",
      "path": "/?action=login",
      "body": {
        "action": "login",
        "login": "sokolov",
        "password": "definitely-wrong-000"
      },
      "expectedStatus": 401
    },
    {
      "name": "Добавление без прав запрещено",
      "method": "POST",
      "path": "/",
      "body": {
        "fullName": "Без прав",
        "position": "Специалист"
      },
      "expectedStatus": 403
    },
    {
      "name": "Смена пароля без авторизации запрещена",
      "method": "POST",
      "path": "/?action=change_password",
      "body": {
        "action": "change_password",
        "oldPassword": "x",
        "newPassword": "newpass"
      },
      "expectedStatus": 401
    }
  ]
}