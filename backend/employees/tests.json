{
  "tests": [
    {
      "name": "Получить список сотрудников",
      "method": "GET",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Успешный вход начальника",
      "method": "POST",
      "path": "/?action=login",
      "body": {
        "action": "login",
        "login": "sokolov",
        "password": "admin123"
      },
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"position": "Начальник отдела"}
    },
    {
      "name": "Неверный пароль",
      "method": "POST",
      "path": "/?action=login",
      "body": {
        "action": "login",
        "login": "sokolov",
        "password": "wrong"
      },
      "expectedStatus": 401
    },
    {
      "name": "Добавление без прав запрещено",
      "method": "POST",
      "path": "/",
      "body": {
        "fullName": "Без прав",
        "position": "Специалист"
      },
      "expectedStatus": 403
    }
  ]
}
